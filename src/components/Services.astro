---
---
<section class="p-5 md:py-20 container mx-auto">
  <div class="mb-12 flex items-end justify-between">
    <h2 class="text-4xl md:text-6xl font-bold text-black tracking-tight leading-none">
      Expertise<span class="text-green">.</span>
    </h2>
    <div class="hidden md:block h-[1px] flex-grow bg-gray-100 ml-8 mb-4"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Large Card: Main Strategy -->
    <div class="col-span-1 md:col-span-5 glass-panel-dark rounded-[30px] p-10 relative overflow-hidden group">
       <div class="relative z-10 flex flex-col justify-between h-full min-h-[280px]">
          <div class="w-12 h-12 bg-white text-black rounded-full flex items-center justify-center mb-6">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg>
          </div>
          <div>
            <h3 class="text-3xl font-bold text-white mb-3">Strategic Consulting</h3>
            <p class="text-gray-400 text-lg max-w-md">Aligning complex technical implementations with organizational goals to optimize workflows.</p>
          </div>
       </div>
    </div>

    <!-- Floating Shape Cell -->
    <div class="hidden md:flex col-span-1 md:col-span-3 items-center justify-center relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-green/20 to-purple/20 rounded-full blur-[60px] opacity-30"></div>
        <img 
            src="/images/iridescent_chrome_abstract_fluid.png" 
            class="w-[140%] h-auto object-contain animate-float z-10 mix-blend-multiply" 
            alt="Decoration" 
        />
    </div>

    <!-- Small Card: Tech Stack -->
    <div class="col-span-1 md:col-span-4 glass-panel rounded-[30px] p-10 flex flex-col justify-between min-h-[280px]">
        <div class="w-12 h-12 bg-gray-50 text-black border border-gray-100 rounded-full flex items-center justify-center mb-6">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
        </div>
        <div>
           <h3 class="text-2xl font-bold text-black mb-2">Full-Stack Dev</h3>
           <p class="text-gray-500">Scalable Python, PL/SQL & Modern Web Apps.</p>
        </div>
    </div>

    <!-- Medium Card: Digital Transformation -->
    <div class="col-span-1 md:col-span-5 glass-panel rounded-[30px] p-10 flex flex-col justify-between min-h-[280px]">
        <div class="w-12 h-12 bg-gray-50 text-black border border-gray-100 rounded-full flex items-center justify-center mb-6">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
        </div>
        <div>
           <h3 class="text-2xl font-bold text-black mb-2">Transformation</h3>
           <p class="text-gray-500">Modernizing legacy systems for innovation.</p>
        </div>
    </div>

    <!-- Large Card: AI & Data -->
    <div class="col-span-1 md:col-span-7 glass-panel rounded-[30px] p-10 relative overflow-hidden group">
        <div class="relative z-10 flex flex-col justify-between h-full">
            <div class="w-12 h-12 bg-green/20 text-black/80 rounded-full flex items-center justify-center mb-6">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/><line x1="3.27" y1="16.96" x2="12" y2="11.96"/><line x1="20.73" y1="16.96" x2="12" y2="11.96"/></svg>
            </div>
            <div>
              <h3 class="text-3xl font-bold text-black mb-3">AI & Data Analytics</h3>
              <p class="text-gray-600 text-lg max-w-lg">Applying machine intelligence and data insights to enhance business foresight, personalization, and efficiency.</p>
            </div>
         </div>
         <div class="absolute top-0 right-0 w-64 h-64 bg-green/10 rounded-full blur-[80px] -mr-20 -mt-20 group-hover:bg-green/20 transition-colors duration-500"></div>
    </div>

  </div>
</section>
