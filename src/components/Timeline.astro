<section class="container mx-auto px-5 mb-20 fade-in-section">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Education -->
    <div class="h-full glass-panel p-8 rounded-[30px] hover:bg-white transition-all duration-300 shadow-sm hover:shadow-md">
      <h3 class="text-2xl font-bold mb-6 text-black">
        Education
      </h3>
      <div class="py-4">
        <p class="text-gray-600 mb-2 font-medium">
          2016 - 2020
        </p>
        <h5 class="text-xl font-bold mb-2 text-black">
          Bachelor of Technology, Computer Engineering
        </h5>
        <p class="text-gray-600">
          Thapar Institute of Engineering and Technology, IN
        </p>
      </div>
    </div>

    <!-- Experiences -->
    <div class="h-full glass-panel text-black p-8 rounded-[30px] hover:bg-white transition-all duration-300 shadow-sm hover:shadow-md">
      <h3 class="text-2xl font-bold mb-6 text-black">
        Professional Experience
      </h3>
      <div class="py-4 space-y-6">
        <div>
            <p class="text-gray-600 mb-1 font-medium text-sm tracking-wide uppercase">Present</p>
            <h5 class="text-xl font-bold mb-2 text-black leading-tight">Deloitte Consulting USI</h5>
            <p class="text-gray-900 font-semibold mb-2">Engagement Lead / Consultant</p>
