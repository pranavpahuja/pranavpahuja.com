---
---
<section class="py-20 bg-green/10 rounded-[30px] my-20 container mx-auto px-5 fade-in-section">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <h6 class="text-sm font-bold uppercase tracking-widest text-green mb-2">
        Quick Contact
      </h6>
      <h2 class="text-5xl md:text-6xl font-bold mb-6 text-black">
        Connect with Me
      </h2>
      <p class="text-xl text-gray-600 mb-4 leading-relaxed">
        I'm always interested in hearing about new projects, opportunities, or sharing insights on the latest in tech.
      </p>
      <p class="text-sm text-gray-400 mb-8 font-medium">
        <span class="text-green mr-2">✓</span> No spam. Confidential. Response within 24 hours.
      </p>
      
      <a href="https://cal.com/pranavpahuja" target="_blank" class="btn-primary inline-flex items-center gap-3 text-lg font-bold uppercase no-underline mb-10" aria-label="Reserve a time slot">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Reserve Time
      </a>

      <!-- Trust Signals -->
      <div class="flex items-center gap-6 opacity-70">
         <div class="flex flex-col">
            <span class="text-2xl font-bold text-black">6+</span>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-500">Years Exp</span>
         </div>
         <div class="w-px h-8 bg-black/10"></div>
         <div class="flex flex-col">
            <span class="text-2xl font-bold text-black">100%</span>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-500">Client Satisfaction</span>
         </div>
      </div>
    </div>

    <div class="glass-panel p-8 md:p-10 rounded-[30px]">
      <form class="space-y-6">
        <div>
          <label for="name" class="sr-only">Name</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            placeholder="your name" 
            class="w-full p-4 bg-white border border-black/10 text-black placeholder:text-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-green focus:bg-white transition-all font-medium"
          >
        </div>
        <div>
          <label for="email" class="sr-only">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="your email" 
            class="w-full p-4 bg-white border border-black/10 text-black placeholder:text-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-green focus:bg-white transition-all font-medium"
          >
        </div>
        <div>
          <label for="message" class="sr-only">Message</label>
          <textarea 
            id="message" 
            name="message" 
            rows="4" 
            placeholder="your message" 
            class="w-full p-4 bg-white border border-black/10 text-black placeholder:text-gray-400 rounded-xl focus:outline-none focus:ring-2 focus:ring-green focus:bg-white transition-all resize-none font-medium"
          ></textarea>
        </div>
        <button type="submit" class="w-full btn-primary text-lg font-bold uppercase">
          Submit
        </button>
      </form>
    </div>
  </div>
</section>
