---
---
<section class="py-20 fade-in-section">
  <div class="container mx-auto px-5">
    <div class="bg-white rounded-[40px] p-10 md:p-16 relative overflow-hidden w-full max-w-[1454px] mx-auto border border-gray-100 shadow-sm">
      
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center relative z-10">
        <!-- Left: Content -->
        <div class="col-span-1 md:col-span-7">
          <h3 class="text-3xl md:text-5xl font-bold text-black mb-12 flex items-center gap-3">
            Certifications <span class="w-3 h-3 rounded-full bg-green animate-pulse"></span>
          </h3>
          
          <div class="space-y-8 max-w-xl">
            <!-- Item 1 -->
            <div class="group flex gap-6 hover:translate-x-2 transition-transform duration-300">
               <div class="w-1 bg-gray-200 group-hover:bg-green transition-colors h-auto rounded-full"></div>
               <div>
                  <span class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1 block">Present</span>
                  <h4 class="text-xl font-bold text-black mb-1">Google Advanced Data Analytics</h4>
                  <p class="text-gray-500">Professional Certificate</p>
               </div>
            </div>

            <!-- Item 2 -->
            <div class="group flex gap-6 hover:translate-x-2 transition-transform duration-300">
               <div class="w-1 bg-gray-200 group-hover:bg-green transition-colors h-auto rounded-full"></div>
               <div>
                  <span class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1 block">Present</span>
                  <h4 class="text-xl font-bold text-black mb-1">Google Data Analytics</h4>
                  <p class="text-gray-500">Professional Certificate</p>
               </div>
            </div>

            <!-- Item 3 -->
            <div class="group flex gap-6 hover:translate-x-2 transition-transform duration-300">
               <div class="w-1 bg-gray-200 group-hover:bg-green transition-colors h-auto rounded-full"></div>
               <div>
                  <span class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-1 block">Present</span>
                  <h4 class="text-xl font-bold text-black mb-1">Oracle Retail Certifications</h4>
                  <p class="text-gray-500">4+ Specialized Actions</p>
               </div>
            </div>
          </div>
        </div>

        <!-- Right: 3D Visual -->
        <div class="col-span-1 md:col-span-5 flex justify-center items-center h-[400px]">
           <div class="relative w-full h-full flex items-center justify-center">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-100/50 to-purple-100/50 rounded-full blur-[80px] opacity-60"></div>
              <img 
                src="/images/iridescent_chrome_geometric_cube.png" 
                alt="3D Cube" 
                class="w-[90%] h-auto object-contain animate-slow-spin drop-shadow-2xl z-10"
                style="filter: drop-shadow(0 30px 60px rgba(0,0,0,0.1));"
              />
           </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slow-spin {
    0% { transform: rotate(0deg) translateY(0px); }
    50% { transform: rotate(5deg) translateY(-10px); }
    100% { transform: rotate(0deg) translateY(0px); }
  }
  .animate-slow-spin {
    animation: slow-spin 10s ease-in-out infinite;
  }
</style>
