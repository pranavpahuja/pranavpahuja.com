---
<section class="container mx-auto px-5 mb-32 fade-in-section relative">
  <!-- Decorative Background Cluster -->
  <div class="absolute left-0 top-0 w-[400px] h-[400px] -z-10 opacity-30 pointer-events-none fade-in-section">
      <img src="/images/iridescent_chrome_shapes_cluster.png" class="w-full h-full object-contain animate-float-slow" alt="Decorative Cluster" />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 border-t border-gray-100 pt-16 relative z-10">
    <div>
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-6 leading-tight">
          How I<br/>Engage<span class="text-gray-300">.</span>
        </h2>
        <p class="text-gray-500 text-lg max-w-sm">Flexible models designed to fit your unique enterprise needs, from advisory to full-scale build.</p>
    </div>

    <div class="grid grid-cols-1 gap-4">
        <div class="group flex items-center justify-between p-6 rounded-2xl bg-gray-50 hover:bg-white border border-transparent hover:border-gray-100 transition-all duration-300">
             <span class="text-lg font-bold text-black">Senior-led, hands-on engagements</span>
             <span class="w-8 h-8 rounded-full bg-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">→</span>
        </div>
        <div class="group flex items-center justify-between p-6 rounded-2xl bg-gray-50 hover:bg-white border border-transparent hover:border-gray-100 transition-all duration-300">
             <span class="text-lg font-bold text-black">Clear outcomes and decision milestones</span>
             <span class="w-8 h-8 rounded-full bg-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">→</span>
        </div>
        <div class="group flex items-center justify-between p-6 rounded-2xl bg-gray-50 hover:bg-white border border-transparent hover:border-gray-100 transition-all duration-300">
             <span class="text-lg font-bold text-black">Flexible models: advisory, build, scale</span>
             <span class="w-8 h-8 rounded-full bg-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">→</span>
        </div>
        <div class="group flex items-center justify-between p-6 rounded-2xl bg-gray-50 hover:bg-white border border-transparent hover:border-gray-100 transition-all duration-300">
             <span class="text-lg font-bold text-black">Confidential, enterprise-grade delivery</span>
             <span class="w-8 h-8 rounded-full bg-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">→</span>
        </div>
    </div>

  </div>
</section>

<style>
  @keyframes float-slow {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(5deg); }
  }
  .animate-float-slow {
      animation: float-slow 12s ease-in-out infinite;
  }
</style>
