---
<section class="mt-[100px] container mx-auto px-5">
    <!-- Clean CSS Background -->
    <div class="absolute inset-0 z-0 bg-white">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.1),rgba(255,255,255,0))]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_120%,rgba(185,255,102,0.15),rgba(255,255,255,0))]"></div>
    </div>

    <div class="text-content text-black relative z-20 h-full flex flex-col justify-center px-10 md:px-20">
      <p class="text-xl md:text-2xl font-bold uppercase tracking-wide text-green mb-4">Senior Software Engineer & Consultant</p>
      <h1 class="text-6xl md:text-8xl font-bold leading-tight mb-6 text-black">Pranav<br>Pahuja</h1>
      
      <p class="text-xl md:text-2xl font-medium text-gray-700 max-w-3xl leading-relaxed mb-8">
        Strategy, data & systems builder with experience in enterprise transformation.
      </p>

      <div class="flex flex-wrap gap-4 text-sm md:text-base font-medium text-black/80 mb-8">
        <span class="bg-black/5 px-4 py-2 rounded-full border border-black/5">6+ Years Experience</span>
        <span class="bg-black/5 px-4 py-2 rounded-full border border-black/5">Enterprise Solutions</span>
        <span class="bg-black/5 px-4 py-2 rounded-full border border-black/5">Data & AI</span>
      </div>

      <div class="border-t border-black/5 pt-6 mt-2 max-w-md">
         <p class="text-sm text-gray-600 font-medium tracking-wide">
          Also: Founder, <a href="https://www.prnvp.com" target="_blank" class="hover:text-gray-900 transition-colors underline decoration-dotted underline-offset-4">prnvp&co</a> <span class="text-gray-500">(Advisory Context)</span>
        </p>
      </div>
    </div>
  </div>
</section>
