---
---
<section class="min-h-[90vh] flex items-center pt-24 pb-12">
    <div class="container mx-auto px-5">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            
            <!-- Left: Typography -->
            <div class="flex flex-col justify-center order-2 lg:order-1 fade-in-section">
                <div class="inline-flex items-center gap-2 mb-6">
                    <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
                    <span class="text-sm font-medium tracking-widest uppercase text-gray-500">Engagement Lead & Strategy Consultant</span>
                </div>

                <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold leading-[0.95] tracking-tight mb-8 text-black">
                    Digital<br/>Transformation<br/>
                    <span class="text-gray-400">& Strategy.</span>
                </h1>

                <p class="text-xl md:text-2xl text-gray-600 max-w-lg leading-relaxed mb-10">
                    Eliminating 95% of manual operations and safeguarding revenue-critical workflows for Fortune 500 retailers through AI-enabled digital transformation.
                </p>

                <div class="flex flex-wrap gap-3 mb-12">
                    <span class="px-5 py-2.5 bg-gray-50 border border-gray-100 rounded-full text-sm font-medium text-gray-600">Engagement Leadership</span>
                    <span class="px-5 py-2.5 bg-gray-50 border border-gray-100 rounded-full text-sm font-medium text-gray-600">Strategic Planning</span>
                    <span class="px-5 py-2.5 bg-gray-50 border border-gray-100 rounded-full text-sm font-medium text-gray-600">Value Realization</span>
                </div>

                <div class="flex items-center gap-4">
                     <a href="/Pranav_Resume.pdf" class="btn-primary group flex items-center gap-2" aria-label="Download Resume" title="Download Resume">
                        Executive Bio
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                    <div class="flex gap-3 px-6 py-3 border-l border-gray-100">
                        <a href="https://linkedin.com/in/prnvp" target="_blank" class="text-gray-400 hover:text-green transition-colors" aria-label="LinkedIn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.3c0-1.26 0-2.88-1.75-2.88s-2 1.36-2 2.78v5.4h-3.55V9h3.4v1.56h.05a3.74 3.74 0 0 1 3.36-1.84c3.6 0 4.26 2.37 4.26 5.45v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45z"/></svg>
                        </a>
                        <a href="https://github.com/pranavpahuja" target="_blank" class="text-gray-400 hover:text-green transition-colors" aria-label="GitHub">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.4.7-4.1-1.6-4.1-1.6a3.3 3.3 0 0 0-1.4-1.8c-1.1-.7.1-.7.1-.7a2.7 2.7 0 0 1 2 1.3 2.8 2.8 0 0 0 3.8 1 2.8 2.8 0 0 1 .8-1.8c-2.7-.3-5.6-1.3-5.6-5.8a4.5 4.5 0 0 1 1.2-3.2 4.2 4.2 0 0 1 .1-3.1s1-.3 3.3 1.2a11.3 11.3 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2a4.2 4.2 0 0 1 .1 3.1 4.5 4.5 0 0 1 1.2 3.2c0 4.5-2.9 5.5-5.6 5.8a3.1 3.1 0 0 1 .9 2.4v3.6c0 .3.2.7.8.6A12 12 0 0 0 12 .3Z"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right: 3D Visual -->
            <div class="relative order-1 lg:order-2 flex justify-center lg:justify-end fade-in-section">
                <div class="relative w-full max-w-[600px] aspect-square flex items-center justify-center">
                    <!-- Decorative back glow -->
                    <div class="absolute inset-0 bg-gradient-to-tr from-green/20 to-purple-300/20 rounded-full blur-[80px] opacity-40"></div>
                    
                    <!-- 3D Asset -->
                    <img 
                        src="/images/iridescent_chrome_torus_hero.png" 
                        alt="Abstract 3D Shape" 
                        class="w-full h-full object-contain relative z-10 animate-float mix-blend-multiply scale-110"
                        style="mask-image: radial-gradient(closest-side, black 60%, transparent 100%); -webkit-mask-image: radial-gradient(closest-side, black 60%, transparent 100%);"
                    />
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(2deg); }
    }
    .animate-float {
        animation: float 8s ease-in-out infinite;
    }
</style>
